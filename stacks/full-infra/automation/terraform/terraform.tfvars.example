aws_region          = "eu-west-1"
aws_profile         = "default"
ec2_instance_type   = "t4g.micro"
vpc_name            = "containerize-vpc"
security_group_name = "containerize-sg"
key_pair_name       = "containerize-key"
public_key          = "ssh-ed25519 AAAA...  your-comment"  # cat ~/.ssh/id_ed25519.pub
allowed_ssh_cidr    = "YOUR_PUBLIC_IP/32"                   # curl ifconfig.me