**/.DS_Store
*.key
*.pem
*.p12
*.pfx

AGENTS.md
context/
# SSH host keys — private keys must never be committed
modules/file-transfer/configs/ssh/ssh_host_ed25519_key
modules/file-transfer/configs/ssh/ssh_host_rsa_key

# Client key pairs — private key must never be committed
modules/file-transfer/configs/keys/labuser_ed25519

# Runtime data — not tracked, recreated on deploy
modules/file-transfer/data/

# TLS certificates — generated locally, never committed
modules/reverse-proxy/configs/traefik/certs/*

# 1. Bloquear los binarios locales (Los plugins descargados por init)
.terraform/

# 2. Bloquear archivos de estado local (CONTIENEN SECRETOS EN TEXTO PLANO)
# Nunca deben subirse a GitHub bajo ningún concepto.
- .tfstate
*.tfstate.*

# 3. Bloquear el archivo de bloqueo de estado local de ejecución
.terraform.tfstate.lock.info

# 4. Bloquear archivos de variables de entorno específicas (Credenciales/Fijos locales)
# Aquí es donde meterás contraseñas o IPs específicas de tus entornos más adelante.
- .tfvars
*.tfvars.json

# 5. Bloquear archivos de Plan de Ejecución guardados de forma externa
# (Pueden contener datos sensibles generados durante el plan)
- .tfplan
*.tfgraph.png

# 6. Logs de caídas del motor
crash.log
crash.*.log