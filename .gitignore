**/.DS_Store
*.key
*.pem
*.p12
*.pfx

AGENTS.md
context/

# SSH host keys — private keys must never be committed
modules/file-transfer/configs/ssh/ssh_host_ed25519_key
modules/file-transfer/configs/ssh/ssh_host_rsa_key

# Client key pairs — private key must never be committed
modules/file-transfer/configs/keys/labuser_ed25519

# Runtime data — not tracked, recreated on deploy
modules/file-transfer/data/

# TLS certificates — generated locally, never committed
modules/reverse-proxy/configs/traefik/certs/*

# Terraform — local plugins downloaded by init
.terraform/

# Terraform — state files contain secrets in plain text, never commit
*.tfstate
*.tfstate.*
terraform.tfvars
*.tfvars.json
stacks/full-infra/automation/terraform/main.tf
stacks/full-infra/automation/terraform/outputs.tf

# Terraform — lock file for local execution state
.terraform.tfstate.lock.info

# Terraform — saved plan files can contain sensitive data
*.tfplan
*.tfgraph.png

# Terraform — crash logs
crash.log
crash.*.log

# cursorignore
.cursorignore
